<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favorites Page</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/css/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
</head>


<% locals.title = 'My Favorites' %>
<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class = "favorites-main">
  <h1>My Favorites</h1>
  <h2>Songs</h2>
  <% if (favorites.length === 0) { %>
    <p>No favorite songs yet. <a href="/artist">Search for songs!</a></p>
  <% } else { %>
    <ul>
      <% favorites.forEach(fav => { %>
        <li>
          <strong><%= fav.songTitle %></strong> — <%= fav.artistName %>
          <form method="POST" action="/user/favorites/song/delete/<%= fav.fav_songId %>" style="display:inline">
            <button type="submit">✕</button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <h2>Artists</h2>
  <% if (favArtists.length === 0) { %>
    <p>No favorite artists yet.</p>
  <% } else { %>
    <ul>
      <% favArtists.forEach(a => { %>
        <li>
          <img src="<%= a.artistImgUrl %>" alt="<%= a.artistName %>" width="50">
          <%= a.artistName %>
          <form method="POST" action="/user/favorites/artist/delete/<%= a.fav_artistId %>" style="display:inline">
            <button type="submit">✕</button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } %>
</main>

<%- include('partials/footer') %>
