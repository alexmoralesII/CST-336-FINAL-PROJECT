<% locals.title = 'My Favorites' %>
<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main>
  <h1>My Favorites</h1>

  <h2>Songs</h2>
  <% if (favorites.length === 0) { %>
    <p>No favorite songs yet. <a href="/artist">Search for songs!</a></p>
  <% } else { %>
    <ul>
      <% favorites.forEach(fav => { %>
        <li>
          <strong><%= fav.songTitle %></strong> — <%= fav.artistName %>
          <form method="POST" action="/user/favorites/song/delete/<%= fav.fav_songId %>" style="display:inline">
            <button type="submit">✕</button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } %>

  <h2>Artists</h2>
  <% if (favArtists.length === 0) { %>
    <p>No favorite artists yet.</p>
  <% } else { %>
    <ul>
      <% favArtists.forEach(a => { %>
        <li>
          <img src="<%= a.artistImgUrl %>" alt="<%= a.artistName %>" width="50">
          <%= a.artistName %>
          <form method="POST" action="/user/favorites/artist/delete/<%= a.fav_artistId %>" style="display:inline">
            <button type="submit">✕</button>
          </form>
        </li>
      <% }) %>
    </ul>
  <% } %>
</main>

<%- include('partials/footer') %>
