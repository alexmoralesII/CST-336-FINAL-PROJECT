<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/css/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <h1>Event Search</h1>

    <div id="search-section">
        <form action="/events/search" method="GET">
            <input type="text" name="artist" placeholder="Search for an artist..." />
            <button type="submit">Search</button>
        </form>
    </div>

    <% if (events) { %>
        <div id="events-section">
            <h2><%= artist %></h2>

            <% if (events.length === 0) { %>
                <p>No upcoming events found for <%= artist %>.</p>
            <% } else { %>
                <div id="events-grid">
                    <% for (let i of events) { %>
                        <div class="event-card">
                            <h3 class="event-artist"><%= i.name %></h3>
                            <p class="event-date"><%= new Date(i.startDate).toDateString() %></p>
                            <p class="event-venue"><%= i.location.name %></p>
                            <p class="event-city">
                                <%= i.location.address.addressLocality %>,
                                <%= i.location.address.addressRegion.name %></p>
                            <a class="event-link" href="<%= i.url %>" target="_blank">Get Tickets</a>
                        </div>
                    <% } %>
                </div>
                <div id="pagination-buttons">
                    <button id="prev-btn">Previous</button>
                    <button id="next-btn">Next</button>
                </div>
            <% } %>
        </div>
    <% } %>

    <%- include('partials/footer.ejs') %>

    <script>
        const events = document.querySelectorAll('.event-card');
        const eventsPerPage = 6;
        let currentPage = 0;

        function showPage(page) {
            let start = page * eventsPerPage;
            let end = start + eventsPerPage;

            for (let i = 0; i < events.length; i++) {
                if (i >= start && i < end) {
                    events[i].style.display = 'block';
                } else {
                    events[i].style.display = 'none';
                }
            }
        }

        function updateButtons() {
            document.getElementById('prev-btn').style.display = currentPage === 0 ? 'none' : 'inline-block';
            document.getElementById('next-btn').style.display = (currentPage + 1) * eventsPerPage >= events.length ? 'none' : 'inline-block';
        }

        if (events.length > 0) {
            showPage(currentPage);
            updateButtons();

            document.getElementById('next-btn').addEventListener('click', () => {
                currentPage++;
                showPage(currentPage);
                updateButtons();
            });

            document.getElementById('prev-btn').addEventListener('click', () => {
                currentPage--;
                showPage(currentPage);
                updateButtons();
            });
        }
    </script>
</body>
</html>