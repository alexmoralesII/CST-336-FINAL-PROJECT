<% locals.title = 'Artist Search' %>
<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main>
  <h1>Artist Search</h1>

  <form method="GET" action="/artist/search">
    <input type="text" name="artist" placeholder="Enter artist name" value="<%= artist || '' %>">
    <button type="submit">Search</button>
  </form>

  <% if (error) { %><p class="error"><%= error %></p><% } %>

  <% if (songs && songs.length > 0) { %>
    <h2>Songs by <%= artist %></h2>
    <ul>
      <% songs.forEach(s => { %>
        <li>
          <a href="/artist/lyrics?artist=<%= encodeURIComponent(s.artist.name) %>&song=<%= encodeURIComponent(s.title) %>">
            <%= s.title %>
          </a>
        </li>
      <% }) %>
    </ul>
  <% } else if (songs) { %>
    <p>No songs found.</p>
  <% } %>

  <% if (lyrics) { %>
    <h2><%= song %> — <%= artist %></h2>
    <pre><%= lyrics %></pre>

    <% if (locals.fullName) { %>
      <form method="POST" action="/artist/favorite">
        <input type="hidden" name="artist" value="<%= artist %>">
        <input type="hidden" name="song"   value="<%= song %>">
        <button type="submit">♥ Save to Favorites</button>
      </form>
    <% } %>
  <% } %>
</main>

<%- include('partials/footer') %>
