<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Artist Page</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/css/styles.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <h1 class="bg-info text-white p-3 m-0">Artist Search</h1>


    <div id="search-section">
        <form action="/artist/search" method="GET">
            <input type="text" name="artist" placeholder="Search for an artist..." />
            <button type="submit">Search</button>
        </form>
    </div>

    <% if (songs) { %>
        <div id="song-list-section">
            <h2><%= artist %></h2>

            <div id="page-wrapper">
                <div id="song-list" class="container-fluid">
                    <% for (let i of songs) { %>
                        <div class="song-row">
                            <a href="/artist/lyrics?artist=<%= i.artist.name %>&song=<%= i.title %>">
                                <%= i.title %>
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>

            <div id="nav-buttons">
                <a href="/artist">New Search</a>
            </div>
            <div id="pagination-buttons">
                <button id="prev-btn">Previous</button>
                <button id="next-btn">Next</button>
            </div>
        </div>
    <% } %>

    <% if (lyrics) { %>
        <div id="lyrics-section">
            <div id="page-wrapper">

                <div id="left-col">
                    <div id="artist-info-box">
                        <h2><%= artist %></h2>
                        <h3><%= song %></h3>
                    </div>
                </div>

                <div id="right-col">
                    <div id="lyrics-box">
                        <pre><%= lyrics %></pre>
                    </div>
                </div>

            </div>

            <div id="nav-buttons">
                <a href="/artist/search?artist=<%= artist %>">Back to Songs</a>
                <a href="/artist">New Search</a>
            </div>
        </div>
    <% } %>



    <%- include('partials/footer.ejs') %>

    <script>
        const songs = document.querySelectorAll('.song-row');
        const songsPerPage = 15;
        let currentPage = 0;

        function showPage(page) {
            let start = page * songsPerPage;
            let end = start + songsPerPage;

            for (let i = 0; i < songs.length; i++) {
                if (i >= start && i < end) {
                    songs[i].style.display = 'block';
                } else {
                    songs[i].style.display = 'none';
                }
            }
        }

        function updateButtons() {
            document.getElementById('prev-btn').style.display = currentPage === 0 ? 'none' : 'inline-block';
            document.getElementById('next-btn').style.display = (currentPage + 1) * songsPerPage >= songs.length ? 'none' : 'inline-block';
        }

        if (songs.length > 0) {
            showPage(currentPage);
            updateButtons();

            document.getElementById('next-btn').addEventListener('click', () => {
                currentPage++;
                showPage(currentPage);
                updateButtons();
            });

            document.getElementById('prev-btn').addEventListener('click', () => {
                currentPage--;
                showPage(currentPage);
                updateButtons();
            });
        }
    </script>
</body>
    
    </html>